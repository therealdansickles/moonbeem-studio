# Env var placeholders — NEVER real values. Real values live in Vercel env
# settings + local .env.local (gitignored). This file was created with the
# health endpoint (2026-07); pre-existing vars are documented in Vercel and
# get added here as they're touched, not retroactively.

# Secret path segment for GET /api/health/[slug] (the keyword-monitor pipeline
# probe). Generate with: openssl rand -hex 16
HEALTH_CHECK_SLUG=replace-with-24-plus-char-random-slug

# Mux DATA API token ("Moonbeem Partner Data"), Data:Read scope ONLY. SEPARATE
# from the Video token (MUX_TOKEN_ID/SECRET), which stays Video-scoped. Powers the
# partner dashboard's per-title view counts (getMuxData(), src/lib/mux.ts).
MUX_DATA_TOKEN_ID=replace-with-mux-data-token-id
MUX_DATA_TOKEN_SECRET=replace-with-mux-data-token-secret
